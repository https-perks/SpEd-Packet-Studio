# Copy these values into environment variables. Do not commit credentials.
# The first two values must exactly match the app identity reserved in Partner Center.
MSIX_IDENTITY_NAME=YOUR_PARTNER_CENTER_IDENTITY_NAME
MSIX_PUBLISHER=CN=YOUR_PARTNER_CENTER_PUBLISHER_ID
MSIX_PUBLISHER_DISPLAY_NAME=Your publisher display name
# Optional. When omitted, build-msix.ps1 uses version.json plus a fourth .0.
MSIX_VERSION=

# Optional for a locally installable/sideloaded package. Partner Center signs
# Store-distributed packages. Never commit the PFX or password.
MSIX_CERTIFICATE_PATH=C:\secure\codesigning.pfx
MSIX_CERTIFICATE_PASSWORD=
MSIX_TIMESTAMP_URL=http://timestamp.digicert.com
